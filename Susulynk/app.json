{
  "expo": {
    "name": "Susulynk",
    "slug": "susulynk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A6B3C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.susulynk.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#1A6B3C"
      },
      "package": "com.susulynk.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
