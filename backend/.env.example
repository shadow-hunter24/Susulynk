# Database — Neon PostgreSQL
# Get this from your Neon dashboard → Connection string → "Prisma" format
# The extra params below are required to avoid cold-start timeouts on Neon free tier:
#   connect_timeout=30    — wait up to 30s for Neon to wake from sleep
#   pool_timeout=30       — wait up to 30s for a free connection in the pool
#   connection_limit=10   — allow up to 10 concurrent connections
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&connect_timeout=30&pool_timeout=30&connection_limit=10"

# JWT
JWT_SECRET="your_strong_jwt_secret_here"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# Server
PORT=3000
NODE_ENV=development

# App
FRONTEND_URL="http://localhost:8081"
